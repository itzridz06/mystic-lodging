<% layout("/layouts/boilerplate") %>

<body>

<h3 class="mb-3">All Listings</h3>

<!-- Filters -->
<div class="filters d-flex justify-content-between mb-4">

  <div class="filter text-center">
    <i class="fa-solid fa-house"></i>
    <p>Rooms</p>
  </div>

  <div class="filter text-center">
    <i class="fa-solid fa-mountain"></i>
    <p>Mountains</p>
  </div>

  <div class="filter text-center">
    <i class="fa-solid fa-water"></i>
    <p>Beach</p>
  </div>

  <div class="filter text-center">
    <i class="fa-solid fa-tree"></i>
    <p>Camping</p>
  </div>

  <div class="filter text-center">
    <i class="fa-solid fa-building"></i>
    <p>City</p>
  </div>

</div>

<!-- Tax Toggle -->
<div class="tax-toggle mb-3">
  <div class="form-check form-switch">
    <input 
      class="form-check-input" 
      type="checkbox" 
      role="switch" 
      id="taxSwitch"
    >
    <label class="form-check-label" for="taxSwitch">
      Display total before taxes
    </label>
  </div>
</div>

<!-- Listings Grid -->
<div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 g-4">

  <% for(let listing of allListings){ %>

    <div class="col">

      <a href="/listings/<%= listing._id %>" class="text-dark listing-link">

        <div class="card listing-card h-100">

          <img 
            src="<%= listing.image.url %>" 
            class="card-img-top" 
            alt="listing_image"
          >

          <div class="card-body">

            <p class="card-text">

              <b><%= listing.title %></b><br>

              <span 
                class="price" 
                data-price="<%= listing.price %>"
              >
                &#8377;<%= listing.price.toLocaleString("en-IN") %>
              </span> / night

            </p>

          </div>

        </div>

      </a>

    </div>

  <% } %>

</div>

</body>